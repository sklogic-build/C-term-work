#include <stdio.h>
#include <math.h>
int main()
{
    int a,b,c;
    float r1,r2,d,real,imag;
    printf("Enter the coefficients of a,b and c");
    scanf("%d%d%d",&a,&b,&c);
    if(a==0)
    {
        printf("Not a quadratic equation. \n");
    }
    else
    {
        d=(b*b)-(4*a*c);
        printf("d = %f\n", d);
        if(d>0)
        {
            r1=(-b+sqrt(d))/(2*a);
            r2=(-b-sqrt(d))/(2*a);
            printf("Real and different roots:%f and %f \n" ,r1 ,r2);
        }
        else if(d==0)
        {
           r1=r2=-b/(2.0*a);
            printf("Real and equal roots:%f and %f \n" ,r1 ,r2);
        }
        else
        {
            real = -b / (2.0*a);
            imag = sqrt(-d) / (2*a);

            printf("Roots are complex:\n");
            printf("r1 = %f + %fi\n", real, imag);
            printf("r2 = %f - %fi\n", real, imag);
        }
    }
    return 0;
}
