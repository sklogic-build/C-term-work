#include <stdio.h>
int main()
{
    int n,a=0,b=1,i,sum;
    printf("Enter the range for fibonacci series: \n");
    scanf("%d",&n);
    printf("The fibonacci series for n= %d \n",n);
    for(i=0;i<n;i++)
    {
        printf("%d",a);
        printf("\n");
        sum=a+b;
        a=b;
        b=sum;
    }
    return 0;
}
