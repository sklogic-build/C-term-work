#include <stdio.h>
int main()
{
    int n, i, rev, num, digit;
    printf("--Input-- \n");
    printf("Enter the value of n:\n");
    scanf("%d", &n);
    printf("Enter the array elements: \n");
    int a[n];
    for(i=0; i<n; i++)
    {
        scanf("%d", &a[i]);
    }
    for(i=0; i<n; i++)
    {
        num= a[i];
        rev= 0;

        while(num > 0)
        {
            digit= num % 10;
            rev= rev * 10 + digit;
            num= num / 10;
        }
        a[i] = rev;
    }
    printf("--Output-- \n");
    printf("After reversing the array elements: \n");
    for(i=0; i<n; i++)
    {
        printf("%d \n",a[i]);
    }
    return 0;
}
