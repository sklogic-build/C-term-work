#include <stdio.h>
int main()
{
    char ch;
    
    printf("Enter the character:");
    scanf("%c", &ch);
        if((ch>='A' && ch<='Z') || (ch>='a' && ch<='z'))
        {
            printf("It is an alphabet %c \n" ,ch);
        }
        else if(ch>='0' && ch<='9')
        {
            printf("It is a number %c \n" ,ch ); 
        }
        else
        {
            printf("It is a special %c symbol \n",ch);
        }
    return 0;
}
